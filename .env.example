# ARMGUARD RDS V1 — Environment Configuration
# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and must NEVER be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Django secret key — generate a new one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Set to True ONLY for local development. Never True in production.
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames. Required when DEBUG=False.
# Example: DJANGO_ALLOWED_HOSTS=192.168.1.100,armguard.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# G5 FIX: Admin URL path segment. Change to something obscure in production
# to prevent automated scanners from reaching the admin login page.
# Example: DJANGO_ADMIN_URL=hq-operations-panel
DJANGO_ADMIN_URL=secure-admin

# ── Unit / Armory identification (printed on reports) ─────────────────────────
# These appear on the Daily Firearms Evaluation printed report.
ARMGUARD_ARMORER_NAME=
ARMGUARD_ARMORER_RANK=
ARMGUARD_COMMANDER_NAME=
ARMGUARD_COMMANDER_RANK=
ARMGUARD_COMMANDER_BRANCH=PAF
ARMGUARD_COMMANDER_DESIGNATION=Squadron Commander

# ── Magazine issuance limits (override doctrinal defaults) ────────────────────
# Maximum pistol magazines issuable per withdrawal. Default: 4.
ARMGUARD_PISTOL_MAGAZINE_MAX_QTY=4
# Maximum rifle magazines issuable per withdrawal. Default: unlimited (leave blank).
# ARMGUARD_RIFLE_MAGAZINE_MAX_QTY=

# ── REST API authentication (G12) ─────────────────────────────────────────────
# Set to True to enable the read-only DRF API at /api/v1/
# Tokens are issued via POST /api/v1/auth/token/
ARMGUARD_API_ENABLED=False

# ── Security (production) ─────────────────────────────────────────────────────
# Uncomment and set when running behind HTTPS (production only).
# SECURE_HSTS_SECONDS=31536000
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ── Error tracking (optional) ────────────────────────────────────────────────
# Uncomment and set your Sentry DSN to enable error tracking.
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
