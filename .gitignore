# C4 FIX: Database file — contains all personnel data, credentials, transaction history.
# Never commit to version control.
project/db.sqlite3
*.sqlite3
# SQLite WAL mode auxiliary files (created automatically when WAL is active).
*.sqlite3-shm
*.sqlite3-wal

# L8 FIX: Collected static output — regenerated by collectstatic, not source files.
project/staticfiles/

# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment / secrets
.env
.env.*
!.env.example

# Google service-account key files — NEVER commit private keys
*.json
!package.json
!package-lock.json
project/utils/googlesheet/

# Virtual environment
venv/
.venv/
env/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.suo
*.user

# Django media uploads (runtime content — not source code)
project/media/**
!project/media/**/
!project/media/**/.gitkeep
# Font Awesome webfonts (downloaded at deploy time by update-server.sh)
project/armguard/static/css/fontawesome/webfonts/

# General cache directories
.cache/
cache/

# Log files (created by the LOGGING config in settings.py)
project/logs/
logs/
*.log

# Coverage reports
.coverage
htmlcov/

# Pytest cache
.pytest_cache/

# Distribution
dist/
build/
*.egg-info/
