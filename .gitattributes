# Normalize all text files to LF on commit (prevents CRLF noise from Windows)
* text=auto eol=lf

# Explicitly LF for server-side files
scripts/*.sh text eol=lf
scripts/*.conf text eol=lf
scripts/*.service text eol=lf
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.sqlite3 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
