# ── ARMGUARD RDS V1 — .dockerignore ─────────────────────────────────────────
# Prevents unnecessary files from being sent to the Docker build context.

# Python bytecode
**/__pycache__/
**/*.py[cod]
**/*.pyo

# Virtual environment
venv/
.venv/
env/

# Version control
.git/
.gitignore

# Editor / IDE artefacts
.vscode/
.idea/
*.swp
*.swo

# Documentation / session artefacts
docs/
*.md
!README.md

# Local environment file (DO NOT copy into image — inject at runtime via --env-file)
.env

# Test artefacts
**/.pytest_cache/
**/pytest.ini
htmlcov/
.coverage

# SQLite development database (use volume mount for persistence)
project/db.sqlite3

# Collected static files (generated inside the container during build)
project/staticfiles/

# Log files
project/logs/
