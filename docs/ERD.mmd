    AUTH_USER        ||--o{    DELETED_RECORD      : "deleted_by"
    AUTH_USER        ||--o{    PASSWORD_HISTORY    : "previous passwords"
    AUTH_USER        ||--o{    SIMULATION_RUN      : "started_by"
    AUTH_USER        ||--o|    PERSONNEL           : "linked account"
    AUTH_USER        ||--o|    CAMERA_DEVICE       : "paired device (1:1)"
    AUTH_USER        ||--o{    CAMERA_UPLOAD_LOG   : "uploaded_by"

    CATEGORY         ||--o{    PISTOL              : "classifies"
    CATEGORY         ||--o{    RIFLE               : "classifies"
    CATEGORY         ||--o{    MAGAZINE            : "classifies"
    CATEGORY         ||--o{    AMMUNITION          : "classifies"
    CATEGORY         ||--o{    ACCESSORY           : "classifies"

    PERSONNEL        ||--o{    PISTOL              : "pistols assigned"
    PERSONNEL        ||--o{    RIFLE               : "rifles assigned"

