    RIFLE            ||--o{    TRANSACTION_LOGS    : "withdraw / return rifle"
    MAGAZINE         ||--o{    TRANSACTION_LOGS    : "withdraw / return mag"
    AMMUNITION       ||--o{    TRANSACTION_LOGS    : "withdraw / return ammo"

