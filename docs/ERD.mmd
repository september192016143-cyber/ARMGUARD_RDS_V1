    RIFLE            ||--o{    TRANSACTION         : "rifle"
    MAGAZINE         ||--o{    TRANSACTION         : "pistol magazine"
    MAGAZINE         ||--o{    TRANSACTION         : "rifle magazine"
    AMMUNITION       ||--o{    TRANSACTION         : "pistol ammunition"
    AMMUNITION       ||--o{    TRANSACTION         : "rifle ammunition"

    PERSONNEL        ||--|{    TRANSACTION_LOGS    : "logged (PROTECT)"
